# =============================================================
# SPECULA — Configuration
# =============================================================
# Copier ce fichier en .env et adapter les valeurs.
# Le fichier .env n'est jamais commité.
# =============================================================

# --- Timezone & Réseau ---
TZ=Europe/Paris
SURICATA_INTERFACE=eth0        # Interface réseau écoutée par Suricata (auto-détectée si vide)

# --- Specula Core ---
SPECULA_MODE=prod
SPECULA_SURICATA_EVE_PATH=/var/log/suricata/eve.json

# --- Fonctionnalités ---
SPECULA_ENABLE_WAZUH=false              # Passer à true avec --profile wazuh
SPECULA_ENABLE_DETECTIONS_FALLBACK=false
SPECULA_USE_TEST_DETECTIONS=false
SPECULA_ALLOW_LOW_VALUE_SURICATA=false

# --- Wazuh (requis si SPECULA_ENABLE_WAZUH=true) ---
WAZUH_BASE_URL=https://wazuh-manager:55000
WAZUH_USERNAME=wazuh-wui
WAZUH_PASSWORD=MyS3cr37P450r.*-
WAZUH_INDEXER_URL=https://wazuh-indexer:9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=SecretPassword
WAZUH_VERIFY_TLS=false
WAZUH_TIMEOUT=10
