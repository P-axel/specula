# =============================================================
# SPECULA — Configuration
# =============================================================
# Copier ce fichier en .env et adapter les valeurs.
# Le fichier .env n'est JAMAIS commité (voir .gitignore).
#
# ⚠️  SÉCURITÉ — À lire avant de déployer :
#   1. Changer TOUS les mots de passe avant toute exposition réseau
#   2. Activer SPECULA_AUTH_ENABLED=true si la console est accessible
#      depuis un réseau non-isolé
#   3. Générer un SPECULA_AUTH_SECRET aléatoire :
#        python3 -c "import secrets; print(secrets.token_hex(32))"
#   4. Passer WAZUH_VERIFY_TLS=true avec un certificat valide en prod
# =============================================================

# --- Timezone & Réseau ---
TZ=Europe/Paris
# SURICATA_INTERFACE=eth0     # Interface réseau (auto-détectée si non définie)

# --- Specula Core ---
SPECULA_MODE=prod
SPECULA_SURICATA_EVE_PATH=/var/log/suricata/eve.json

# --- Base de données annotations ---
# Chemin de la base SQLite (persistée dans runtime/db/)
# SPECULA_DB_PATH=/app/runtime/db/specula.db

# --- Authentification ---
# ⚠️  Désactivé par défaut (mode local/lab). Activer en réseau partagé.
SPECULA_AUTH_ENABLED=false
# ⚠️  OBLIGATOIRE : changer cette valeur avant toute mise en production
SPECULA_AUTH_SECRET=change-me-in-production
SPECULA_AUTH_USERNAME=admin
# ⚠️  Changer ce mot de passe
SPECULA_AUTH_PASSWORD=specula
SPECULA_AUTH_TOKEN_EXPIRE_MINUTES=480

# --- Fonctionnalités ---
SPECULA_ENABLE_WAZUH=false              # Passer à true avec make up → option 2
SPECULA_ENABLE_DETECTIONS_FALLBACK=false
SPECULA_USE_TEST_DETECTIONS=false
SPECULA_ALLOW_LOW_VALUE_SURICATA=false

# --- Wazuh (requis si SPECULA_ENABLE_WAZUH=true) ---
WAZUH_BASE_URL=https://wazuh-manager:55000
# ⚠️  Changer ces credentials Wazuh
WAZUH_USERNAME=wazuh
WAZUH_PASSWORD=wazuh
WAZUH_INDEXER_URL=https://wazuh-indexer:9200
WAZUH_INDEXER_USERNAME=admin
# ⚠️  Changer ce mot de passe indexer
WAZUH_INDEXER_PASSWORD=SecretPassword
# ⚠️  Passer à true avec un certificat valide en production
WAZUH_VERIFY_TLS=false
WAZUH_TIMEOUT=10
